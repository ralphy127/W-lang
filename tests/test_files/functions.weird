gig add(x, y) {
    yeet x with y...
}

gig subtract(x, y) {
    yeet x without y...
}

gig multiply(a, b) {
    yeet a with a with b...
}

gig double(x) {
    yeet x with x...
}

gig isGreater(x, y) {
    yeet x bigger_ish y...
}

gig isEqual(a, b) {
    yeet a looks_like b...
}

gig macho() {
    scream: "Testing functions"...
    
    stash sum about add(2, 3)...
    scream: "2 + 3 ="...
    scream: sum...
    
    stash diff about subtract(10, 3)...
    scream: "10 - 3 ="...
    scream: diff...
    
    stash product about multiply(3, 2)...
    scream: "3 * 2 + 3 ="...
    scream: product...
    
    stash doubled about double(5)...
    scream: "5 * 2 ="...
    scream: doubled...
    
    stash greater about isGreater(7, 4)...
    scream: "7 > 4 ="...
    scream: greater...
    
    stash equal about isEqual(5, 5)...
    scream: "5 == 5 ="...
    scream: equal...
    
    stash nested about add(add(1, 2), add(3, 4))...
    scream: "nested add(add(1,2), add(3,4)) ="...
    scream: nested...
    
    scream: "Testing function in loop"...
    stash i about 1...
    spin_around (3) {
        stash result about double(i)...
        scream: result...
        i might_be i with 1...
    }
    
    scream: "Testing function in condition"...
    stash total about add(5, 5)...
    perhaps (total looks_like 10) {
        scream: "5 + 5 equals 10 - correct"...
    }
    screw_it {
        scream: "Something went wrong"...
    }
    
    scream: "All tests completed"...
    yeet ghosted...
}
