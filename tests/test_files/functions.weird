summon gossip...

gig add(x, y) {
    yeet x with y...
}

gig subtract(x, y) {
    yeet x without y...
}

gig multiply(a, b) {
    yeet a with a with b...
}

gig double(x) {
    yeet x with x...
}

gig isGreater(x, y) {
    yeet x bigger_ish y...
}

gig isEqual(a, b) {
    yeet a looks_like b...
}

gig macho() {
    gossip.spill_tea("Testing functions")...
    
    stash sum about add(2, 3)...
    gossip.spill_tea("2 + 3 =")...
    gossip.spill_tea(sum)...
    
    stash diff about subtract(10, 3)...
    gossip.spill_tea("10 - 3 =")...
    gossip.spill_tea(diff)...
    
    stash product about multiply(3, 2)...
    gossip.spill_tea("3 * 2 + 3 =")...
    gossip.spill_tea(product)...
    
    stash doubled about double(5)...
    gossip.spill_tea("5 * 2 =")...
    gossip.spill_tea(doubled)...
    
    stash greater about isGreater(7, 4)...
    gossip.spill_tea("7 > 4 =")...
    gossip.spill_tea(greater)...
    
    stash equal about isEqual(5, 5)...
    gossip.spill_tea("5 == 5 =")...
    gossip.spill_tea(equal)...
    
    stash nested about add(add(1, 2), add(3, 4))...
    gossip.spill_tea("nested add(add(1,2), add(3,4)) =")...
    gossip.spill_tea(nested)...
    
    gossip.spill_tea("Testing function in loop")...
    stash i about 1...
    spin_around (3) {
        stash result about double(i)...
        gossip.spill_tea(result)...
        i might_be i with 1...
    }
    
    gossip.spill_tea("Testing function in condition")...
    stash total about add(5, 5)...
    perhaps (total looks_like 10) {
        gossip.spill_tea("5 + 5 equals 10 - correct")...
    }
    screw_it {
        gossip.spill_tea("Something went wrong")...
    }
    
    gossip.spill_tea("All tests completed")...
    yeet ghosted...
}
