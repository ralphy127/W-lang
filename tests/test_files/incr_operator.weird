summon gossip...

gig macho() {
    stash number about 0...
    gossip.spill_tea(number)...
    pump_it number...
    gossip.spill_tea(number)...
    gossip.spill_tea("-------------")...

    stash count about 0...
    do_until_bored {
        gossip.spill_tea(count)...
        pump_it count...
        perhaps (count bigger_ish 9) {
            rage_quit!!!
        }
    }

    yeet ghosted...
}