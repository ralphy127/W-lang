gig macho() {
    stash number about 0...
    scream: number...
    pump_it number...
    scream: number...
    scream: "-------------"...

    stash count about 0...
    do_until_bored {
        scream: count...
        pump_it count...
        perhaps (count bigger_ish 9) {
            rage_quit!!!
        }
    }

    yeet ghosted...
}