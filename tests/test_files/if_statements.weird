summon gossip...

gig macho() {
    psst: Test 1: Simple if with boolean literal
    perhaps (totally) {
        gossip.spill_tea("Test 1")...
    }

    psst: Test 2: Simple if with false condition
    perhaps (nah) {
        gossip.spill_tea("FAILED Test 2 - should not print")...
    }

    psst: Test 3: If-else with true condition
    perhaps (totally) {
        gossip.spill_tea("Test 3 if branch")...
    }
    screw_it {
        gossip.spill_tea("FAILED Test 3 - else should not run")...
    }

    psst: Test 4: If-else with false condition
    perhaps (nah) {
        gossip.spill_tea("FAILED Test 4 - if should not run")...
    }
    screw_it {
        gossip.spill_tea("Test 4 else branch")...
    }

    psst: Test 5: If-else if-else chain
    stash value about 15...
    perhaps (value tiny_ish 10) {
        gossip.spill_tea("FAILED Test 5 - should match else if")...
    }
    or_whatever (value looks_like 15) {
        gossip.spill_tea("Test 5 - Value is exactly 15")...
    }
    screw_it {
        gossip.spill_tea("FAILED Test 5 - should match else if")...
    }

    psst: Test 6: Multiple else if conditions
    stash score about 75...
    perhaps (score bigger_ish 90) {
        gossip.spill_tea("FAILED Test 6 - Grade A")...
    }
    or_whatever (score bigger_ish 80) {
        gossip.spill_tea("FAILED Test 6 - Grade B")...
    }
    or_whatever (score bigger_ish 70) {
        gossip.spill_tea("Test 6 - Grade C")...
    }
    screw_it {
        gossip.spill_tea("FAILED - Grade F")...
    }

    psst: Test 7: Nested if statements
    stash x about 10...
    stash y about 20...
    perhaps (x tiny_ish 15) {
        perhaps (y bigger_ish 15) {
            gossip.spill_tea("Test 7 - both conditions true")...
        }
    }

    psst: Test 8: If with equality comparison
    stash name about 42...
    perhaps (name looks_like 42) {
        gossip.spill_tea("Test 8 - Name equals 42")...
    }

    psst: Test 9: If with inequality comparison
    stash age about 25...
    perhaps (age kinda_sus 30) {
        gossip.spill_tea("Test 9 - Age is not 30")...
    }

    psst: Test 10: If with variable boolean
    stash isReady about totally...
    perhaps (isReady looks_like totally) {
        gossip.spill_tea("Test 10 - System is ready")...
    }

    psst: Test 11: Complex nested if-else
    stash num about 50...
    perhaps (num bigger_ish 40) {
        perhaps (num tiny_ish 60) {
            gossip.spill_tea("Test 11 - Number is between 40 and 60")...
        }
    }

    psst: Test 12: If with floating point comparison
    stash temperature about 98.6...
    perhaps (temperature looks_like 98.6) {
        gossip.spill_tea("Test 12 - Normal temperature")...
    }

    psst: Test 13: Multiple independent if statements
    stash flag1 about totally...
    stash flag2 about totally...
    perhaps (flag1 looks_like totally) {
        gossip.spill_tea("Test 13a - Flag 1 is true")...
    }
    perhaps (flag2 looks_like totally) {
        gossip.spill_tea("Test 13b - Flag 2 is true")...
    }

    psst: Test 14: If-else with variable reassignment inside
    stash counter about 5...
    perhaps (counter tiny_ish 10) {
        counter might_be 15...
        gossip.spill_tea("Test 14 - Counter updated to 15")...
    }

    psst: Test 15: If statement checking false explicitly
    stash isError about nah...
    perhaps (isError looks_like nah) {
        gossip.spill_tea("Test 15 - explicit false")...
    }

    gossip.spill_tea("All if statement tests completed")...
    yeet ghosted...
}
