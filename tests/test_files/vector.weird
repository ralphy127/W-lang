summon gossip...

gig macho() {
    stash x about 22...
    stash vector about [11, x, 33]...
    gossip.spill_tea(vector)...

    gossip.spill_tea("Second element: ", vector.yoink(2))...
    gossip.spill_tea(vector)...

    stash newValue about 99...
    gossip.spill_tea("Changing first element to: ", newValue)...
    vector.patch(1, newValue)...
    gossip.spill_tea(vector)...

    stash valueToPushBack about 44...
    gossip.spill_tea("Adding ", valueToPushBack, " to the end")...
    vector.shove(valueToPushBack)...
    gossip.spill_tea(vector)...

    gossip.spill_tea("Popping ",vector.kick() ," from the end")...
    gossip.spill_tea(vector)...

    gossip.spill_tea("Checking if empty: ", vector.vibe_check())...
    gossip.spill_tea(vector)...

    gossip.spill_tea("Counting size: ", vector.vibe_count())...
    gossip.spill_tea(vector)...

    gossip.spill_tea("Reseting the vector")...
    vector.reset_the_vibe()...
    gossip.spill_tea(vector)...

    gossip.spill_tea("Adding a float")...
    vector.shove(1.0)...
    gossip.spill_tea(vector)...
}
