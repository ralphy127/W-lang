summon gossip...

gig macho() {
    stash x about 22...
    stash vector about [11, x, 33]...
    gossip.spill_tea(vector)...

    psst: gossip.spill_tea("Second element from 'yoink': ", vector.yoink(2))...

    psst: stash newValue about gossip.eavesdrop("Change first element to 404: ")...
    psst: vector.patch(1, newValue)...
    psst: gossip.spill_tea("Vector after 'patch': ", vector)...
}