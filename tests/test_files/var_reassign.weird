summon gossip...

gig macho() {
    stash counter about 0...
    stash number about 0...
    do_until_bored {
        gossip.spill_tea(counter)...
        gossip.spill_tea(number)...
        counter might_be counter with 1...
        number might_be number without 1...
        perhaps (counter bigger_ish 9) {
            rage_quit!!!
        }
    }
}