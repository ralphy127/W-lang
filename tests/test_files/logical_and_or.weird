summon gossip...

gig macho() {
    stash number about 3...
    perhaps (number bigger_ish 0 also number tiny_ish 5) {
        gossip.spill_tea("OK")...
    }
    screw_it {
        gossip.spill_tea("NOK")...
    }

    perhaps (number tiny_ish 2 either number looks_like 0) {
        gossip.spill_tea("NOK")...
    }
    screw_it {
        gossip.spill_tea("OK")...
    }
}